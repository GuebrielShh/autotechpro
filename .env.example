# Backend
PORT=3001
NODE_ENV=development

# Frontend (para producción)
VITE_API_URL=/api

# Base de datos (cuando se implemente)
# DATABASE_URL=mongodb://localhost:27017/autotechpro

# Métodos de pago (cuando se implemente)
# MERCADOPAGO_KEY=your_key_here
# PAYPAL_CLIENT_ID=your_id_here
# STRIPE_KEY=your_key_here

# Autenticación (cuando se implemente)
# JWT_SECRET=your_secret_here

# GDPR y Cookies
GDPR_ENABLED=true
COOKIE_EXPIRY_DAYS=365
RETURN_POLICY_DAYS=30

# Email para contacto
CONTACT_EMAIL=contact@autotechpro.com
SUPPORT_EMAIL=support@autotechpro.com
RETURNS_EMAIL=returns@autotechpro.com
